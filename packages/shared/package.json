{
  "name": "@plasticine-react/shared",
  "version": "0.0.0",
  "description": "internal utils shared across @plasticine-react packages.",
  "type": "module",
  "main": "./dist/cjs/shared.js",
  "module": "./dist/esm/shared.js",
  "types": "./dist/shared.d.ts",
  "exports": {
    ".": {
      "require": "./dist/cjs/shared.js",
      "import": "./dist/esm/shared.js",
      "types": "./dist/shared.d.ts"
    }
  },
  "buildConfig": {
    "name": "ReactShared",
    "formats": [
      "cjs",
      "esm"
    ]
  },
  "keywords": [
    "shared",
    "plasticine-react"
  ],
  "author": "Plasticine-Yang",
  "license": "MIT"
}
